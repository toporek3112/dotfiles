# copy to clipboard 
alias c='xclip'
alias v='xclip -o'

# ansible - wol
alias woloff="docker run --rm --network host \
        -v \"$HOME/home_lab/ansible\":/ansible \
        -v \"$HOME/.ssh\":~/.ssh \
        -w /ansible \
        --entrypoint bash \
        -it 311200/debug-tools:0.0.1-arm64 \
        -c \"chown root /root/.ssh/*; ansible-playbook -i inventory.yaml power/power-off_nodes.yaml\""

alias wolon="docker run --rm --network host \
        -v \"$HOME/home_lab/ansible\":/ansible \
        -v \"$HOME/.ssh\":/root/.ssh \
        -w /ansible \
        --entrypoint bash \
        -it 311200/debug-tools:0.0.1-arm64 \
        -c \"chown root /root/.ssh/*; ansible-playbook -i inventory.yaml power/power-on_nodes_jumphost.yaml\""

alias ansible-playbook="ansible-playbook -i $HOME/home_lab/ansible/inventory.yaml"
alias ansible="ansible -i $HOME/home_lab/ansible/inventory.yaml"

